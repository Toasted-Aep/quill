<Window
    x:Class="Quill.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:Quill.Controls"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Grid x:Name="RootGrid" Background="{ThemeResource SurfaceBrush}" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoAccel_Invoked"/>
            <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="RedoAccel_Invoked"/>
            <KeyboardAccelerator Key="Delete" Invoked="DeleteAccel_Invoked"/>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyAccel_Invoked"/>
            <KeyboardAccelerator Key="X" Modifiers="Control" Invoked="CutAccel_Invoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="PasteAccel_Invoked"/>
            <KeyboardAccelerator Key="F11" Invoked="FullscreenAccel_Invoked"/>
            <KeyboardAccelerator Key="F1" Invoked="ShortcutsAccel_Invoked"/>
            <KeyboardAccelerator Key="Escape" Invoked="EscAccel_Invoked"/>
            <KeyboardAccelerator Key="D" Modifiers="Control" Invoked="DuplicateAccel_Invoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control,Shift" Invoked="PastePlainTextAccel_Invoked"/>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="SearchAccel_Invoked"/>
            <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="PaletteAccel_Invoked"/>
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== TOP BAR ===================== -->
        <!-- Canvas.ZIndex keeps the bar above anything that escapes the canvas row,
             so unclipped text bubbles can never cover or block its buttons (#3-batch2) -->
        <Border x:Name="TopBar" Grid.Row="0" Padding="8,5" Canvas.ZIndex="100"
                Background="{ThemeResource CardBrush}"
                BorderBrush="{ThemeResource HairlineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            <ScrollViewer x:Name="TopBarScroll" Grid.Column="0" HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Enabled"
                          VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled"
                          PointerWheelChanged="BarScroll_Wheel">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <ToggleButton x:Name="BtnSidebar" IsChecked="True" Click="Sidebar_Toggle"
                                  ToolTipService.ToolTip="Show or hide the notebook panel">
                        <FontIcon Glyph="&#xE700;" FontSize="14"/>
                    </ToggleButton>
                    <!-- takes the hamburger's spot while the start screen is open -->
                    <Button x:Name="BtnSettings" Click="Settings_Click" Visibility="Collapsed"
                            ToolTipService.ToolTip="Settings — accent colour, startup, storage folder &amp; import">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                    <TextBlock x:Name="CrumbText" VerticalAlignment="Center" Margin="6,0,10,0"
                               FontSize="13" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold"
                               Foreground="{ThemeResource InkBrush}"
                               MaxWidth="320" TextTrimming="CharacterEllipsis"/>

                    <AppBarSeparator/>

                    <ToggleButton x:Name="ToolPen" Tag="Pen" Click="ToolButton_Click" ToolTipService.ToolTip="Pen (draw)">
                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolText" Tag="Text" Click="ToolButton_Click" ToolTipService.ToolTip="Text (tap the page to add a text box)">
                        <FontIcon Glyph="&#xE8D2;" FontSize="14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolSelect" Tag="Select" Click="ToolButton_Click" ToolTipService.ToolTip="Lasso select (or hold the pen's second button)">
                        <FontIcon Glyph="&#xE8B3;" FontSize="14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolSpace" Tag="FreeSpace" Click="ToolButton_Click" ToolTipService.ToolTip="Insert free space (drag down to push content apart)">
                        <TextBlock Text="&#x2195;" FontSize="14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="TouchDrawToggle" Click="TouchDraw_Click"
                                  ToolTipService.ToolTip="Touch draw: draw with finger or mouse (otherwise touch pans)">
                        <TextBlock Text="&#x261D;" FontSize="13"/>
                    </ToggleButton>
                    <Button x:Name="ShapeBtn" ToolTipService.ToolTip="Insert a perfect shape (or draw one and hold the pen still!)">
                        <TextBlock Text="&#x25A2;" FontSize="14"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Straight line" Tag="Line" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Arrow" Tag="Arrow" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Rectangle" Tag="Rect" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Square" Tag="Square" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Ellipse" Tag="Ellipse" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Circle" Tag="Circle" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Triangle" Tag="Triangle" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Right triangle" Tag="RightTriangle" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Diamond" Tag="Diamond" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Parallelogram" Tag="Parallelogram" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Trapezoid" Tag="Trapezoid" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Pentagon" Tag="Pentagon" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Hexagon" Tag="Hexagon" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="Star" Tag="Star" Click="InsertShape_Click"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="x-y plane" Tag="AxesXY" Click="InsertShape_Click"/>
                                <MenuFlyoutItem Text="x-y-z axes" Tag="AxesXYZ" Click="InsertShape_Click"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Table…" Click="InsertTable_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE80A;"/></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Equation (typed)…" Click="InsertEquation_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE943;"/></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <DropDownButton x:Name="MouseModeBtn" ToolTipService.ToolTip="Mouse mode — how the mouse behaves while the pen tool is active">
                        <TextBlock x:Name="MouseModeGlyph" Text="&#x2196;" FontSize="14" VerticalAlignment="Center"/>
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <RadioMenuFlyoutItem x:Name="MouseAuto" Tag="Auto" GroupName="MouseMode" IsChecked="True"
                                                     Text="Auto — click to select or edit, drag empty space to select" Click="MouseMode_Click"/>
                                <RadioMenuFlyoutItem x:Name="MouseGrab" Tag="Grab" GroupName="MouseMode"
                                                     Text="Grab — drag to pan the page" Click="MouseMode_Click"/>
                                <RadioMenuFlyoutItem x:Name="MouseSelect" Tag="Select" GroupName="MouseMode"
                                                     Text="Select — drag a box to select strokes" Click="MouseMode_Click"/>
                                <RadioMenuFlyoutItem x:Name="MouseMove" Tag="Move" GroupName="MouseMode"
                                                     Text="Move — drag images and shapes; drag a handle to resize" Click="MouseMode_Click"/>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <AppBarSeparator/>

                    <Button x:Name="BtnUndo" Click="Undo_Click" ToolTipService.ToolTip="Undo (Ctrl+Z)">
                        <FontIcon Glyph="&#xE7A7;" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnRedo" Click="Redo_Click" ToolTipService.ToolTip="Redo (Ctrl+Y)">
                        <FontIcon Glyph="&#xE7A6;" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnHistory" ToolTipService.ToolTip="Edit history &amp; replay">
                        <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout x:Name="HistoryFlyout" Opening="HistoryFlyout_Opening">
                                <StackPanel Width="240">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock x:Uid="EditHistoryHeader" Text="Edit history" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="BtnReplay" Click="Replay_Click" HorizontalAlignment="Right"
                                                      Width="34" Height="34" Padding="0"
                                                      Background="Transparent" BorderThickness="0"
                                                      ToolTipService.ToolTip="Replay this page stroke by stroke">
                                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                        </ToggleButton>
                                    </Grid>
                                    <ListView x:Name="HistoryList" MaxHeight="320" SelectionMode="None"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <AppBarSeparator/>

                    <ToggleButton x:Name="BtnAudioRecording" Click="BtnAudioRecording_Click" ToolTipService.ToolTip="Toggle audio recording panel">
                        <FontIcon Glyph="&#xE720;" FontSize="14"/>
                    </ToggleButton>

                    <AppBarSeparator/>

                    <DropDownButton x:Name="ZoomBtn" ToolTipService.ToolTip="Zoom &amp; view">
                        <TextBlock x:Name="ZoomBtnText" Text="100%" FontSize="12" MinWidth="34" TextAlignment="Center"/>
                        <DropDownButton.Flyout>
                            <Flyout>
                                <StackPanel Spacing="8" Width="190">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <Button Click="ZoomOut_Click" ToolTipService.ToolTip="Zoom out" Width="46">
                                            <FontIcon Glyph="&#xE71F;" FontSize="14"/>
                                        </Button>
                                        <Button Click="ZoomReset_Click" ToolTipService.ToolTip="Reset zoom to 100%" Width="60">
                                            <TextBlock Text="100%" FontSize="12"/>
                                        </Button>
                                        <Button Click="ZoomIn_Click" ToolTipService.ToolTip="Zoom in" Width="46">
                                            <FontIcon Glyph="&#xE8A3;" FontSize="14"/>
                                        </Button>
                                    </StackPanel>
                                    <Button Click="HomeView_Click" HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Back to origin (the page is infinite!)">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                                            <TextBlock Text="Back to origin" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ZoomFit_Click" HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Fit page content to window">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE9A6;" FontSize="14"/>
                                            <TextBlock Text="Zoom to fit" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <AppBarSeparator/>

                    <Button x:Name="PageSettingsBtn" ToolTipService.ToolTip="Page background and grid">
                        <FontIcon Glyph="&#xE790;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Width="280" Spacing="10">
                                    <Grid>
                                        <TextBlock x:Uid="BackgroundHeader" Text="Background" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <!-- Apple-style light/dark pill: sun on one side, moon on the other -->
                                        <Grid x:Name="ThemeToggle" Width="62" Height="30" HorizontalAlignment="Right"
                                              Background="Transparent" Tapped="ThemeToggle_Tapped"
                                              ToolTipService.ToolTip="Switch light / dark mode">
                                            <Border CornerRadius="15" Background="#30808080"
                                                    BorderBrush="{ThemeResource HairlineBrush}" BorderThickness="1"/>
                                            <FontIcon Glyph="&#xE706;" FontSize="13" HorizontalAlignment="Left"
                                                      Margin="8,0,0,0" Opacity="0.85"/>
                                            <FontIcon Glyph="&#xE708;" FontSize="12" HorizontalAlignment="Right"
                                                      Margin="0,0,8,0" Opacity="0.85"/>
                                            <Border Width="26" Height="26" CornerRadius="13" HorizontalAlignment="Left"
                                                    Margin="2,0,0,0" Background="#FAF9F5"
                                                    BorderBrush="#66808080" BorderThickness="1">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="ThemeKnobTT"/>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Tag="#FAF9F5" Click="BgPreset_Click" ToolTipService.ToolTip="Ivory" Width="40" Height="28" Background="#FAF9F5" BorderBrush="Gray"/>
                                        <Button Tag="#FFFFFF" Click="BgPreset_Click" ToolTipService.ToolTip="White" Width="40" Height="28" Background="White" BorderBrush="Gray"/>
                                        <Button Tag="#1E1E1E" Click="BgPreset_Click" ToolTipService.ToolTip="Dark grey" Width="40" Height="28" Background="#1E1E1E" BorderBrush="Gray"/>
                                        <Button Tag="#000000" Click="BgPreset_Click" ToolTipService.ToolTip="Total black (OLED)" Width="40" Height="28" Background="Black" BorderBrush="Gray"/>
                                    </StackPanel>
                                    <Expander Header="Custom colour" HorizontalAlignment="Stretch">
                                        <ColorPicker x:Name="BgPicker" IsAlphaEnabled="False" IsMoreButtonVisible="False"
                                                     ColorSpectrumShape="Box" IsColorSliderVisible="True"
                                                     ColorChanged="BgPicker_ColorChanged"/>
                                    </Expander>
                                    <Button Click="SetDefaultBg_Click" FontSize="12" HorizontalAlignment="Stretch"
                                            Content="Use this page's colour for all new pages"/>
                                    <Button Click="SetNotebookDefaultBg_Click" FontSize="12" HorizontalAlignment="Stretch"
                                            Content="Set as default colour for this notebook"/>
                                    <RadioButtons x:Name="GridRadios" Header="Gridlines" SelectionChanged="GridRadios_SelectionChanged">
                                        <x:String>None</x:String>
                                        <x:String>Dotted</x:String>
                                        <x:String>Squares</x:String>
                                        <x:String>Row lines</x:String>
                                    </RadioButtons>
                                    <TextBlock x:Uid="GridSpacingHeader" Text="Grid spacing" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold"/>
                                    <Slider x:Name="SpacingSlider" Minimum="16" Maximum="96" StepFrequency="4"
                                            ValueChanged="SpacingSlider_ValueChanged"/>
                                    <Button Click="SetDefaultGrid_Click" FontSize="12" HorizontalAlignment="Stretch"
                                            Content="Use this grid for all new pages"/>
                                    <Button Click="SetNotebookDefaultGrid_Click" FontSize="12" HorizontalAlignment="Stretch"
                                            Content="Set as default grid for this notebook"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button x:Name="ExportBtn" ToolTipService.ToolTip="Export the whole page">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutSubItem Text="Export page">
                                    <MenuFlyoutItem Text="PDF" Click="ExportVectorPdf_Click"/>
                                    <MenuFlyoutItem Text="PNG" Click="ExportPng_Click"/>
                                    <MenuFlyoutItem Text="SVG (vector)" Click="ExportSvg_Click"/>
                                    <MenuFlyoutItem Text="HTML (vector)" Click="ExportHtml_Click"/>
                                    <MenuFlyoutItem Text="Copy as image" Click="CopyPageImage_Click"/>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutSubItem Text="Export section">
                                    <MenuFlyoutItem Text="PDF" Click="ExportSectionVectorPdf_Click"/>
                                    <MenuFlyoutItem Text="PNG images (folder)…" Click="ExportSectionPngs_Click"/>
                                    <MenuFlyoutItem Text="Markdown + images…" Click="ExportSectionMarkdown_Click"/>
                                    <MenuFlyoutItem Text="HTML (vector)" Click="ExportSectionHtml_Click"/>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutSubItem Text="Export notebook">
                                    <MenuFlyoutItem Text="PDF" Click="ExportNotebookVectorPdf_Click"/>
                                    <MenuFlyoutItem Text="Markdown + images…" Click="ExportNotebookMarkdown_Click"/>
                                    <MenuFlyoutItem Text="HTML (vector)" Click="ExportNotebookHtml_Click"/>
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <AppBarSeparator/>

                    <ToggleButton x:Name="BtnCalc" Click="Calc_Toggle" ToolTipService.ToolTip="Calculator">
                        <FontIcon Glyph="&#xE8EF;" FontSize="14"/>
                    </ToggleButton>
                </StackPanel>
            </ScrollViewer>
            <!-- pinned at the far right, outside the scrolling row (#20-batch2) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
                <AppBarSeparator/>
                <Button x:Name="BtnHideUi" Click="HideUi_Click" ToolTipService.ToolTip="Minimal UI (hide all panels)">
                    <FontIcon Glyph="&#xE890;" FontSize="14"/>
                </Button>
                <Button x:Name="BtnFullscreen" Click="Fullscreen_Click" ToolTipService.ToolTip="Full screen (F11)">
                    <FontIcon x:Name="BtnFullscreenIcon" Glyph="&#xE740;" FontSize="14"/>
                </Button>
            </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== TEXT FORMAT BAR ===================== -->
        <Border x:Name="FormatBar" Grid.Row="1" Padding="8,4" Visibility="Collapsed"
                Background="{ThemeResource CardBrush}"
                BorderBrush="{ThemeResource HairlineBrush}"
                BorderThickness="0,0,0,1">
            <ScrollViewer x:Name="FormatBarScroll" HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Enabled"
                          VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled"
                          PointerWheelChanged="BarScroll_Wheel">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <ComboBox x:Name="StyleCombo" Width="130" SelectionChanged="StyleCombo_Changed"
                               PlaceholderText="Styles" ToolTipService.ToolTip="Text styles (brand typography)"/>
                    <Button Click="StyleChip_Click" Tag="Heading 1" Content="H1" FontSize="11" Padding="6,2" ToolTipService.ToolTip="Heading 1" AllowFocusOnInteraction="False"/>
                    <Button Click="StyleChip_Click" Tag="Heading 2" Content="H2" FontSize="11" Padding="6,2" ToolTipService.ToolTip="Heading 2" AllowFocusOnInteraction="False"/>
                    <Button Click="StyleChip_Click" Tag="Normal" Content="Normal" FontSize="11" Padding="6,2" ToolTipService.ToolTip="Normal text" AllowFocusOnInteraction="False"/>
                    <Button Click="StyleChip_Click" Tag="Code" Content="Code" FontSize="11" Padding="6,2" ToolTipService.ToolTip="Code" AllowFocusOnInteraction="False"/>
                    <ComboBox x:Name="FontCombo" Width="150" SelectionChanged="FontCombo_Changed"
                              ToolTipService.ToolTip="Font family"/>
                    <ComboBox x:Name="SizeCombo" Width="74" IsEditable="True"
                              SelectionChanged="SizeCombo_Changed" TextSubmitted="SizeCombo_TextSubmitted"
                              ToolTipService.ToolTip="Font size — pick one or type any value"/>

                    <AppBarSeparator/>

                    <Button Click="FormatBold_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Bold (Ctrl+B)">
                        <TextBlock Text="B" FontWeight="Bold"/>
                    </Button>
                    <Button Click="FormatItalic_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Italic (Ctrl+I)">
                        <TextBlock Text="I" FontStyle="Italic"/>
                    </Button>
                    <Button Click="FormatUnderline_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Underline (Ctrl+U)">
                        <TextBlock Text="U" TextDecorations="Underline"/>
                    </Button>
                    <Button Click="FormatStrike_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Strikethrough">
                        <TextBlock Text="S" TextDecorations="Strikethrough"/>
                    </Button>
                    <Button Click="FormatSuper_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Superscript">
                        <TextBlock Text="x&#xB2;"/>
                    </Button>
                    <Button Click="FormatSub_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Subscript">
                        <TextBlock Text="x&#x2082;"/>
                    </Button>

                    <AppBarSeparator/>

                    <Button AllowFocusOnInteraction="False" ToolTipService.ToolTip="Text colour">
                        <TextBlock Text="A" Foreground="{StaticResource BrandOrangeBrush}" FontWeight="SemiBold"/>
                        <Button.Flyout>
                            <Flyout>
                                <ColorPicker x:Name="TextColorPicker" IsAlphaEnabled="False" IsMoreButtonVisible="False"
                                             ColorSpectrumShape="Box" ColorChanged="TextColorPicker_ColorChanged"/>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button AllowFocusOnInteraction="False" ToolTipService.ToolTip="Highlight colour">
                        <Border Background="Yellow" Padding="4,0"><TextBlock Text="ab" Foreground="Black"/></Border>
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="8">
                                    <ColorPicker x:Name="HighlightPicker" IsAlphaEnabled="False" IsMoreButtonVisible="False"
                                                 ColorSpectrumShape="Box" ColorChanged="HighlightPicker_ColorChanged"/>
                                    <Button Content="Remove highlight" Click="ClearHighlight_Click"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <AppBarSeparator/>

                    <Button Click="FormatBullets_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Bullet list">
                        <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                    </Button>
                    <Button Click="FormatOutdent_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Decrease indent">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>
                    <Button Click="FormatIndent_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Increase indent">
                        <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                    </Button>
                    <Button Click="FormatChecklist_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Checklist — cycle ☐ / ☑ / none on this line">
                        <TextBlock Text="&#x2611;" FontSize="15"/>
                    </Button>
                    <Button Click="FormatLink_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Add a link to the selected text">
                        <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                    </Button>

                    <AppBarSeparator/>

                    <Button Click="AlignLeft_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Align left">
                        <FontIcon Glyph="&#xE8E4;" FontSize="14"/>
                    </Button>
                    <Button Click="AlignCenter_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Align centre">
                        <FontIcon Glyph="&#xE8E3;" FontSize="14"/>
                    </Button>
                    <Button Click="AlignRight_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Align right">
                        <FontIcon Glyph="&#xE8E2;" FontSize="14"/>
                    </Button>
                    <Button Click="AlignJustify_Click" AllowFocusOnInteraction="False" ToolTipService.ToolTip="Justify">
                        <FontIcon Glyph="&#xE8E1;" FontSize="14"/>
                    </Button>

                    <AppBarSeparator/>

                    <Button AllowFocusOnInteraction="False" ToolTipService.ToolTip="Insert maths symbol">
                        <TextBlock Text="&#x03A9;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel>
                                    <TextBlock Text="Maths symbols" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <GridView x:Name="SymbolGrid" Width="324" MaxHeight="300"
                                              IsItemClickEnabled="True" ItemClick="Symbol_Click" SelectionMode="None">
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="34" Height="34">
                                                    <TextBlock Text="{Binding}" FontSize="17"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===================== CANVAS + FLOATING PANELS ===================== -->
        <Grid x:Name="CanvasArea" Grid.Row="2">
            <ctrl:InkSurface x:Name="Surface"/>

            <!-- Liquid-Glass Floating Audio Recording Panel -->
            <Border x:Name="AudioFloatingPanel" HorizontalAlignment="Center" VerticalAlignment="Top" 
                    Margin="0,14,0,0" Background="{ThemeResource CardBrushFloat}" 
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5" 
                    CornerRadius="18" Padding="12,6" Canvas.ZIndex="10" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="AudioGrip" Text="&#x283F;" FontSize="12" Opacity="0.55"
                               VerticalAlignment="Center" Margin="2,0,0,0" Padding="4,6"
                               ToolTipService.ToolTip="Drag to move this panel"/>
                    <TextBlock Text="🎙️" VerticalAlignment="Center" Margin="0,0,4,0" IsHitTestVisible="False"/>
                    
                    <ToggleButton x:Name="AudioRecordBtn" Click="AudioRecord_Click" ToolTipService.ToolTip="Record lecture audio" 
                                  Width="36" Height="32" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Grid>
                            <Ellipse x:Name="RecordDot" Width="10" Height="10" Fill="Red" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ToggleButton>
                    <TextBlock x:Name="AudioTimeText" Text="0:00" VerticalAlignment="Center" FontSize="12" Width="40" TextAlignment="Center" Opacity="0.8"/>
                    
                    <AppBarSeparator/>
                    
                    <Button x:Name="AudioPlayBtn" Click="AudioPlay_Click" ToolTipService.ToolTip="Play/Pause recording" 
                            Width="32" Height="32" IsEnabled="False" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <FontIcon x:Name="AudioPlayIcon" Glyph="&#xE768;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Slider x:Name="AudioSlider" Minimum="0" Maximum="100" Value="0" Width="100" Height="32" VerticalAlignment="Center" Margin="4,0,4,0" IsEnabled="False"
                            ValueChanged="AudioSlider_ValueChanged"/>
                    <Button x:Name="AudioSpeedBtn" Click="AudioSpeed_Click" Content="1.0x" FontSize="11" 
                            Width="40" Height="32" Padding="0" IsEnabled="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    
                    <AppBarSeparator/>

                    <!-- Save/Export audio file -->
                    <Button x:Name="AudioSaveBtn" Click="AudioSave_Click" ToolTipService.ToolTip="Save/Export audio file" 
                            Width="32" Height="32" IsEnabled="False" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <FontIcon Glyph="&#xE74E;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Floating notebook panel -->
            <Border x:Name="NotebookPanel" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="14,14,0,0" Width="300" MaxHeight="940"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    CornerRadius="{StaticResource CardCorner}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="2,0,0,6">
                        <TextBlock Text="Notebooks" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{ThemeResource InkBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button x:Name="SearchBtn" Padding="4,2" Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Search all notes — text and handwriting (Ctrl+F)">
                                <FontIcon Glyph="&#xE721;" FontSize="11"/>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Width="340" Spacing="8">
                                            <TextBox x:Name="SearchBox" x:Uid="SearchBoxInput" PlaceholderText="Search notes…" KeyDown="SearchBox_KeyDown"/>
                                            <TextBlock x:Name="SearchStatus" FontSize="11" Opacity="0.7"/>
                                            <ListView x:Name="SearchResults" MaxHeight="380" SelectionMode="None"
                                                      IsItemClickEnabled="True" ItemClick="SearchResult_Click"/>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Padding="4,2" Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Order notebooks, sections or pages by date">
                                <FontIcon Glyph="&#xE8CB;" FontSize="11"/>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutSubItem Text="Pages">
                                            <MenuFlyoutItem Text="Newest first" Tag="pg:desc" Click="Order_Click"/>
                                            <MenuFlyoutItem Text="Oldest first" Tag="pg:asc" Click="Order_Click"/>
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSubItem Text="Sections">
                                            <MenuFlyoutItem Text="Newest first" Tag="sec:desc" Click="Order_Click"/>
                                            <MenuFlyoutItem Text="Oldest first" Tag="sec:asc" Click="Order_Click"/>
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSubItem Text="Notebooks">
                                            <MenuFlyoutItem Text="Newest first" Tag="nb:desc" Click="Order_Click"/>
                                            <MenuFlyoutItem Text="Oldest first" Tag="nb:asc" Click="Order_Click"/>
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="Manual order: right-click an item → Move up / down" IsEnabled="False"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Click="Sidebar_Close" Padding="4,2"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Close panel">
                                <FontIcon Glyph="&#xE711;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,0,0,6">
                        <Button Padding="10,4" Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Add a page, section or notebook">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="New page" Click="AddPage_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7C3;"/></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="New section" Click="AddSection_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8B7;"/></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="New notebook" Click="AddNotebook_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8F1;"/></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Import PDF as section…" Click="ImportPdf_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;"/></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Click="OpenGallery_Click" Padding="6,4" ToolTipService.ToolTip="Notebook gallery (colours &amp; folders)">
                            <FontIcon Glyph="&#xE80A;" FontSize="12"/>
                        </Button>
                        <TextBlock Text="Right-click an item for rename, delete, move &amp; lock"
                                   FontSize="10" Opacity="0.55" VerticalAlignment="Center" Margin="4,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TreeView x:Name="NotebookTree" Grid.Row="2"
                              SelectionMode="Single" ItemInvoked="NotebookTree_ItemInvoked"
                              RightTapped="NotebookTree_RightTapped"
                              CanDragItems="False" CanReorderItems="False" AllowDrop="False"/>
                    <Border x:Name="NbGrip" Grid.Row="2" Width="22" Height="22"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,2,-6,-6" Background="Transparent"
                            ToolTipService.ToolTip="Drag to resize this panel">
                        <TextBlock Text="&#x25E2;" FontSize="11" Opacity="0.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Floating pen panel: drag the grip to dock it to any edge -->
            <Border x:Name="PenRow" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="24,0,24,16" Padding="8,6"
                    Background="{ThemeResource CardBrushFloat}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    CornerRadius="{StaticResource CardCorner}">
                <ScrollViewer x:Name="PenScroll" HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled" MaxWidth="1280">
                    <StackPanel x:Name="PenStack" Orientation="Horizontal" Spacing="4">
                        <Border x:Name="PenGrip" Background="Transparent" Padding="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Drag me — dock the pens to any side of the page">
                            <TextBlock Text="⠿" FontSize="13" Opacity="0.55"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel x:Name="PresetPanel" Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="BtnAddPreset" Click="AddPreset_Click" Padding="6,4"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Save the current pen as a new pen (right-click any pen to edit it)">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                        </Button>

                        <DropDownButton x:Name="RulerBtn" Padding="6,4" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.ToolTip="Ruler — draw straight lines at any angle">
                            <TextBlock Text="&#x1F4CF;" FontSize="13" VerticalAlignment="Center"/>
                            <DropDownButton.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="8" Width="230">
                                        <ToggleSwitch x:Name="RulerToggle" Header="Show ruler" Toggled="RulerToggle_Toggled"/>
                                        <TextBlock x:Name="RulerDegLabel" Text="Angle: 0°" FontSize="12"/>
                                        <Slider x:Name="RulerSlider" Minimum="0" Maximum="180" StepFrequency="1" Value="0"
                                                ValueChanged="RulerSlider_Changed"/>
                                        <TextBlock Text="Turn it on, set any angle, then draw with the pen — lines lock to that angle."
                                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>

                        <AppBarSeparator HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Button x:Name="BtnPenRowCollapse" Click="PenRowCollapse_Click"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Hide the pen panel for this page">
                            <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Small floating button when the pen panel is hidden -->
            <Button x:Name="PenRowShowBtn" Click="PenRowShow_Click" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"
                    Width="44" Height="44" CornerRadius="22"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    ToolTipService.ToolTip="Show the pen panel">
                <TextBlock Text="&#x1F58A;" FontSize="16"/>
            </Button>

            <!-- Floating calculator -->
            <Border x:Name="CalcPanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,14,14,0" Width="332" MaxHeight="760"
                    Background="{ThemeResource CardBrushFloat}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    CornerRadius="{StaticResource CardCorner}" Padding="10">
                <StackPanel Spacing="6">
                    <Grid x:Name="CalcHeader" Background="Transparent"
                          ToolTipService.ToolTip="Drag to move the calculator">
                        <TextBlock Text="&#x22EE;&#x22EE;  Calculator" FontFamily="{StaticResource HeadingFont}" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{ThemeResource InkBrush}" VerticalAlignment="Center"/>
                        <Button Click="Calc_Close" HorizontalAlignment="Right" Padding="4,2"
                                Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Close calculator">
                            <FontIcon Glyph="&#xE711;" FontSize="11"/>
                        </Button>
                    </Grid>
                    <ComboBox x:Name="CalcModeBox" HorizontalAlignment="Stretch" FontSize="12"
                              SelectionChanged="CalcModeBox_Changed"/>

                    <StackPanel x:Name="ProgHost" Visibility="Collapsed" Spacing="2">
                        <TextBlock x:Name="ProgHex" FontSize="12" FontFamily="Consolas" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="ProgDec" FontSize="12" FontFamily="Consolas" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="ProgOct" FontSize="12" FontFamily="Consolas" IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="ProgBin" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Input base" FontSize="11" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ProgBase" FontSize="11" SelectionChanged="ProgBase_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <ListView x:Name="CalcHistory" MaxHeight="110"
                              IsItemClickEnabled="True" ItemClick="CalcHistory_Click" SelectionMode="None"
                              FontSize="12"/>
                    <StackPanel x:Name="CalcVarsPanel" Orientation="Horizontal" Spacing="4" Visibility="Collapsed"/>
                    <TextBox x:Name="CalcInput" FontSize="17" PlaceholderText="2sin(45)+√(9)  ·  x = 5"
                             KeyDown="CalcInput_KeyDown" TextChanged="CalcInput_TextChanged" TextWrapping="Wrap"/>
                    <TextBlock x:Name="CalcPreview" FontSize="13" Opacity="0.65" IsTextSelectionEnabled="True"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="Ans" FontSize="11" Click="CalcAns_Click" ToolTipService.ToolTip="Insert the last result"/>
                        <Button Content="MC" FontSize="11" Click="CalcMemClear_Click" ToolTipService.ToolTip="Clear memory"/>
                        <Button Content="MR" FontSize="11" Click="CalcMemRecall_Click" ToolTipService.ToolTip="Recall memory"/>
                        <Button Content="M+" FontSize="11" Click="CalcMemPlus_Click" ToolTipService.ToolTip="Add to memory"/>
                        <Button Content="M−" FontSize="11" Click="CalcMemMinus_Click" ToolTipService.ToolTip="Subtract from memory"/>
                    </StackPanel>
                    <StackPanel x:Name="CalcToggles" Orientation="Horizontal" Spacing="6">
                        <ToggleButton x:Name="CalcDeg" Content="DEG" FontSize="11" IsChecked="True"
                                      ToolTipService.ToolTip="Degrees (off = radians)"/>
                        <ToggleButton x:Name="Calc2nd" Content="2&#x207F;&#x1D48;" FontSize="11" Click="CalcMode_Click"
                                      ToolTipService.ToolTip="Inverse functions"/>
                        <ToggleButton x:Name="CalcHyp" Content="hyp" FontSize="11" Click="CalcMode_Click"
                                      ToolTipService.ToolTip="Hyperbolic functions"/>
                        <TextBlock x:Name="CalcError" FontSize="11" Foreground="{StaticResource BrandOrangeBrush}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="170"/>
                    </StackPanel>
                    <StackPanel x:Name="CalcButtons" Spacing="3"/>

                    <StackPanel x:Name="GraphHost" Visibility="Collapsed" Spacing="6">
                        <TextBox x:Name="GraphInput" FontSize="14" PlaceholderText="sin(x); 0.1x^2"
                                 TextChanged="GraphInput_Changed"/>
                        <canvas:CanvasControl x:Name="GraphCanvas" Height="230" Draw="GraphCanvas_Draw"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="−" FontSize="13" Click="GraphZoomOut_Click" ToolTipService.ToolTip="Wider x range"/>
                            <Button Content="+" FontSize="13" Click="GraphZoomIn_Click" ToolTipService.ToolTip="Narrower x range"/>
                            <Button Content="&#x27F3;" FontSize="13" Click="GraphReset_Click" ToolTipService.ToolTip="Reset range"/>
                            <TextBlock x:Name="GraphRangeText" FontSize="11" VerticalAlignment="Center" Text="x: −10 … 10"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="ConvHost" Visibility="Collapsed" Spacing="6">
                        <ComboBox x:Name="ConvCat" HorizontalAlignment="Stretch" FontSize="12"
                                  SelectionChanged="ConvCat_Changed"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ComboBox x:Name="ConvFrom" Width="130" FontSize="12" SelectionChanged="Conv_Changed"/>
                            <Button Content="&#x21C4;" FontSize="13" Click="ConvSwap_Click" ToolTipService.ToolTip="Swap units"/>
                            <ComboBox x:Name="ConvTo" Width="130" FontSize="12" SelectionChanged="Conv_Changed"/>
                        </StackPanel>
                        <TextBox x:Name="ConvInput" FontSize="16" PlaceholderText="1" TextChanged="Conv_Changed"/>
                        <TextBlock x:Name="ConvResult" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource InkBrush}" IsTextSelectionEnabled="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Minimal-UI floating buttons -->
            <StackPanel x:Name="MinimalButtons" Orientation="Horizontal" Spacing="8" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"
                        ToolTipService.ToolTip="Drag to move — snaps to the nearest corner, or drag flush to the left/right edge to tuck it away">
                <Button x:Name="BtnFloatNotebook" Click="FloatNotebook_Click"
                        Width="42" Height="42" CornerRadius="21"
                        Background="{ThemeResource CardBrushFloat}" BorderBrush="{StaticResource GlowBrush}" BorderThickness="2.25"
                        ToolTipService.ToolTip="Notebooks">
                    <!-- original notebook silhouette (spine + rule lines), themed via Foreground -->
                    <PathIcon Data="M3 1.5 H12 C13.1 1.5 14 2.4 14 3.5 V12.5 C14 13.6 13.1 14.5 12 14.5 H3 Z M4.7 1.5 H5.5 V14.5 H4.7 Z M7 5 H12 V6 H7 Z M7 8 H12 V9 H7 Z"/>
                </Button>
                <Button x:Name="BtnFloatPen" Click="FloatPen_Click"
                        Width="42" Height="42" CornerRadius="21"
                        Background="{ThemeResource CardBrushFloat}" BorderBrush="{StaticResource GlowBrush}" BorderThickness="2.25"
                        ToolTipService.ToolTip="Pens">
                    <!-- original nib-pen silhouette, matches the pen-strip icon set -->
                    <PathIcon Data="M3.5 12.5 L5 9 L11.5 2.5 L13.5 4.5 L7 11 Z M12.3 1.7 L14.3 3.7 L15 3 A1.4 1.4 0 0 0 13 1 Z"/>
                </Button>
                <Button x:Name="BtnRestoreUi" Click="RestoreUi_Click"
                        Width="42" Height="42" CornerRadius="21"
                        Background="{ThemeResource CardBrushFloat}" BorderBrush="{StaticResource GlowBrush}" BorderThickness="2.25"
                        ToolTipService.ToolTip="Show the interface again">
                    <FontIcon Glyph="&#xE890;" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Minimal-UI docked tab: appears when the cluster above is dragged flush
                 against a side edge, so it can be tucked away and pulled back out (#dock) -->
            <Border x:Name="MinimalButtonsTab" Visibility="Collapsed"
                    Width="20" Height="56" CornerRadius="10"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,0,0"
                    Background="{ThemeResource CardBrushFloat}" BorderBrush="{StaticResource GlowBrush}" BorderThickness="2"
                    Tapped="MinimalButtonsTab_Tapped"
                    ToolTipService.ToolTip="Tap or drag out to show the notebooks/pen/exit buttons">
                <FontIcon x:Name="MinimalButtonsTabGlyph" Glyph="&#xE76B;" FontSize="11"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="StatusText" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="14,0,0,12" FontSize="12" Foreground="{ThemeResource InkBrush}"
                       Opacity="0.85" IsHitTestVisible="False"/>

            <Border x:Name="ZoomBorder" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,18,12"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    CornerRadius="8" Padding="8,3" IsHitTestVisible="False">
                <TextBlock x:Name="ZoomText" Text="100%" FontSize="12" Foreground="{ThemeResource InkBrush}"/>
            </Border>

            <!-- ===================== NOTEBOOK GALLERY (#16) ===================== -->
            <!-- F1: liquid-glass shortcut cheat-sheet (#53) -->
            <Border x:Name="ShortcutsPanel" Visibility="Collapsed" Background="{ThemeResource CardBrush}"
                    BorderBrush="{StaticResource GlassEdgeBrush}" BorderThickness="1.5"
                    CornerRadius="{StaticResource CardCorner}" MaxWidth="620" Padding="24,18"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Tapped="Shortcuts_Close">
                <StackPanel Spacing="5">
                    <TextBlock Text="Shortcuts" FontSize="18" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeadingFont}" Foreground="{ThemeResource InkBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="F11"/><Run Text="   Full screen"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Esc"/><Run Text="   Close picker / leave full screen"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Ctrl+F"/><Run Text="   Search all notes"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Ctrl+Z / Ctrl+Y"/><Run Text="   Undo / redo"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Ctrl+C / X / V"/><Run Text="   Copy, cut, paste (ink, images and text)"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Delete"/><Run Text="   Remove the selection"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Ctrl+wheel"/><Run Text="   Zoom · middle-drag pans"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Right-drag"/><Run Text="   Lasso select · right-tap opens the menu"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Pen barrel"/><Run Text="   Tap a selection for its menu · drag to lasso"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Hold after drawing"/><Run Text="   Snap the stroke to a perfect shape"/></TextBlock>
                    <TextBlock FontSize="13" Foreground="{ThemeResource InkBrush}"><Run FontWeight="SemiBold" Text="Pen eraser tip"/><Run Text="   Erase · lasso-selected ink can be dragged with the pen"/></TextBlock>
                    <TextBlock Text="Press F1 or tap to close" FontSize="11" Opacity="0.6" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="GalleryPanel" Visibility="Collapsed" Background="{ThemeResource CardBrush}">
                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="GalleryBackBtn" Click="GalleryBack_Click" Visibility="Collapsed"
                                    Background="Transparent" BorderThickness="0" Padding="8" VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Back to all notebooks (Esc)">
                                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                            </Button>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock x:Name="GalleryTitle" Text="Notebooks" FontFamily="{StaticResource HeadingFont}"
                                           FontWeight="SemiBold" FontSize="24" Foreground="{ThemeResource InkBrush}"/>
                                <TextBlock x:Name="GallerySubtitle" Text="" FontSize="12" Opacity="0.65"
                                           Foreground="{ThemeResource InkBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="GallerySearchBtn" Click="GallerySearch_Click"
                                    ToolTipService.ToolTip="Search all notes — text and handwriting (Ctrl+F)">
                                <FontIcon Glyph="&#xE721;" FontSize="14"/>
                            </Button>
                            <Button x:Name="GallerySaveBtn" Click="GallerySave_Click" Content="Save…" Visibility="Collapsed"
                                    ToolTipService.ToolTip="Export this notebook, one section, or one page as PDF"/>
                            <Button x:Name="GalleryContinueBtn" Click="GalleryContinue_Click" Visibility="Collapsed"
                                    Style="{StaticResource AccentButtonStyle}"/>
                            <Button x:Name="GalleryNbBtn" Click="GalleryNewNotebook_Click" Content="New notebook"/>
                            <Button x:Name="GalleryFolderBtn" Click="GalleryNewFolder_Click" Content="New folder"/>
                            <Button x:Name="GallerySecBtn" Click="GalleryNewSection_Click" Content="New section" Visibility="Collapsed"/>
                            <Button x:Name="GalleryDoneBtn" Click="CloseGallery_Click" Content="Close" ToolTipService.ToolTip="Close the picker (Esc)"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                        <StackPanel x:Name="GalleryHost" Spacing="20"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
