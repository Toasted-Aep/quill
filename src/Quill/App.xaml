<Application
    x:Class="Quill.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#F7F6F1"/>
                    <!-- frosted glass: more translucent so the backdrop reads through -->
                    <AcrylicBrush x:Key="CardBrush" TintColor="#FBFAF6" TintOpacity="0.38"
                                  TintLuminosityOpacity="0.55" FallbackColor="#DCFBFAF6"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#E5E2D8"/>
                    <SolidColorBrush x:Key="InkBrush" Color="#1B1A18"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <!-- cinematic near-black base with a hint of cool -->
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#0F0E10"/>
                    <!-- frosted dark glass panels — more see-through -->
                    <AcrylicBrush x:Key="CardBrush" TintColor="#1A191D" TintOpacity="0.28"
                                  TintLuminosityOpacity="0.38" FallbackColor="#CC15141A"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#2E2D33"/>
                    <SolidColorBrush x:Key="InkBrush" Color="#F4F2EC"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Anthropic brand accents (theme-independent) -->
            <Color x:Key="SystemAccentColor">#D97757</Color>
            <Color x:Key="SystemAccentColorLight1">#E08B6D</Color>
            <Color x:Key="SystemAccentColorLight2">#E89F85</Color>
            <Color x:Key="SystemAccentColorLight3">#F0B49D</Color>
            <Color x:Key="SystemAccentColorDark1">#C76747</Color>
            <Color x:Key="SystemAccentColorDark2">#B05A3C</Color>
            <Color x:Key="SystemAccentColorDark3">#9A4E33</Color>

            <LinearGradientBrush x:Key="GlowBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E6D97757" Offset="0"/>
                <GradientStop Color="#59D97757" Offset="0.35"/>
                <GradientStop Color="#26D97757" Offset="0.5"/>
                <GradientStop Color="#59D97757" Offset="0.65"/>
                <GradientStop Color="#E6D97757" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="BrandOrangeBrush" Color="#D97757"/>
            <SolidColorBrush x:Key="BrandBlueBrush" Color="#6A9BCC"/>
            <SolidColorBrush x:Key="BrandGreenBrush" Color="#788C5D"/>

            <!-- Inter/Geist-style modern sans for chrome; falls back to the
                 Windows 11 variable font, then Poppins, then Segoe UI. -->
            <FontFamily x:Key="HeadingFont">Inter, Geist, Segoe UI Variable Display, Poppins, Segoe UI</FontFamily>
            <FontFamily x:Key="BodyFont">Inter, Geist, Segoe UI Variable Text, Segoe UI</FontFamily>

            <CornerRadius x:Key="CardCorner">18</CornerRadius>
        </ResourceDictionary>
    </Application.Resources>
</Application>
